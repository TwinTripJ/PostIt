<!DOCTYPE html>
<html lang="ko">
  <head>
    <link rel="stylesheet" href="/static/css/searchPage.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>내가 쓴 게시글</title>
    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
  </head>
  <body>
    <%- include("nav") %>

    <div class="backColor">
      <div class="carosel">
        <img
          class="caroselImg"
          src="/static/images/mainCarosel.jpg"
          alt="carosel image"
        />
        <div class="logo">
          <a href="/">
            <img src="/static/images/postitLogo.png" alt="postit logo" />
          </a>
          <form action="/postit/search" method="GET">
            <div class="searchBox">
              <input
                class="search"
                placeholder="검색 키워드를 작성하여 주세요."
                name="name"
              />
              <button type="submit">검색</button>
            </div>
          </form>
        </div>
      </div>

      <div class="mainContainer">
        <% if (Array.isArray(posts) && posts.length > 0) { %>
        <div class="allPostsBox">
          <% for (let i = 0; i < posts.length; i++) { %>
          <div class="allPostContainer">
            <div class="all-post-card">
              <div class="allContentBox">
                <div class="textBox" onclick="moveToPost('<%= posts[i].id %>')">
                  <h2><%= posts[i].title.substring(0, 20) %></h2>
                  <p>
                    작성일: <%= new
                    Date(posts[i].createdAt).toLocaleDateString() %>
                  </p>
                  <p>
                    <%= posts[i].content ? posts[i].content.substring(0, 50) :
                    "내용 없음" %>...
                  </p>
                </div>
                <div class="favoriteContainer">
                  <div class="post-info">
                    <div
                      class="favoriteIcon"
                      onclick="heart(event)"
                      data-fav="<%= posts[i].favorite ? '1' : '0' %>"
                      data-id="<%= posts[i].id %>"
                    >
                      <img
                        src="<%= posts[i].favorite ? '/static/images/favoriteFillIcon.png' : '/static/images/favoriteIcon.png' %>"
                      />
                    </div>
                    <span class="like-count"
                      ><%= posts[i].like_count || 0 %>
                    </span>
                  </div>
                </div>
              </div>
              <img
                src="<%= posts[i] && posts[i].image_url ? posts[i].image_url : '/static/images/default-image.png' %>"
                alt="Post Image"
                class="postImage"
                onclick="moveToPost('<%= posts[i].id %>')"
                data-id="<%= posts[i].id %>"
              />
            </div>
          </div>
          <% } %> <% } else { %>
          <div class="emptyImg">
            <img src="/static/images/postEmpty(white).png" alt="empty image" />
          </div>
          <% } %>
        </div>
      </div>

      <%- include("footer") %>
    </div>
  </body>
  <script src="/static/js/searchPage.js"></script>
</html>
